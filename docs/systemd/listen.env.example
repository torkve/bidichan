# /etc/bidichan/listen.env
#
# Sourced by bidichan@listen.service. BIDICHAN_FLAGS becomes the full
# argument list passed to the bidichan binary. systemd word-splits on
# whitespace, so keep every flag and its value as a single token —
# quoted multi-word values are not supported here.
#
# Make this file root:bidichan 0640 — it carries the pre-shared key.

BIDICHAN_FLAGS=listen --addr :443 --hostname cdn.example.com --psk REPLACEME-HEX-PSK --socket /run/bidichan/listen/control.sock
