# /etc/bidichan/plain.env
#
# Sourced by bidichan@plain.service. Used when bidichan listens on a unix
# socket behind a TLS-terminating reverse proxy (e.g. nginx with
# proxy_pass http://unix:/run/bidichan/data.sock). root:bidichan 0640.

BIDICHAN_FLAGS=listen --unix-socket /run/bidichan/plain/data.sock --hostname cdn.example.com --psk REPLACEME-HEX-PSK --socket /run/bidichan/plain/control.sock
