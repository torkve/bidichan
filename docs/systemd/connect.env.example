# /etc/bidichan/connect.env
#
# Sourced by bidichan@connect.service. See the unit file for word-splitting
# rules. root:bidichan 0640 — contains the PSK.

BIDICHAN_FLAGS=connect --addr cdn.example.com:443 --hostname cdn.example.com --psk REPLACEME-HEX-PSK --socket /run/bidichan/connect/control.sock
